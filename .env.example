# AI DJ local configuration template.
# You normally do not need to edit this file by hand.
# Open the app, click the settings button next to shuffle, fill these values, and save.

# Required for NetEase daily recommendations, user playlists, and member playback.
# Example shape: MUSIC_U=...; __csrf=...
NETEASE_COOKIE=

# AI DJ chat model. Any OpenAI-compatible chat/completions endpoint can be used.
AI_API_FORMAT=openai
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_API_KEY=

# MiMo voice model. Also uses an OpenAI-compatible chat/completions endpoint.
MIMO_TTS_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts-voicedesign
MIMO_TTS_API_KEY=

# Optional playback quality: standard, higher, exhigh, lossless.
NETEASE_LEVEL=exhigh
